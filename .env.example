# AI Model IDs — Environment Variables
# Copy this file to .env and fill in your API keys.
# If a key is missing, that provider will be skipped (cached data used if available).

# OpenAI-compatible providers (all use Bearer token auth)
OPENAI_API_KEY=sk-...
MISTRAL_API_KEY=...
DEEPSEEK_API_KEY=sk-...
XAI_API_KEY=xai-...
MOONSHOT_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
DASHSCOPE_API_KEY=sk-...
ZHIPU_API_KEY=...

# Anthropic (own API format)
ANTHROPIC_API_KEY=sk-ant-...
