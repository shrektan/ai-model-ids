# AI Model IDs — Environment Variables
# Copy this file to .env and fill in your API keys.
# All keys are required for full provider coverage.
# If a key is missing, that provider will be skipped (YAML-based providers always work).

OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...
MISTRAL_API_KEY=...
DEEPSEEK_API_KEY=sk-...
XAI_API_KEY=xai-...
ANTHROPIC_API_KEY=sk-ant-...
